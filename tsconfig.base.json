{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "DOM.Iterable", "ES2021"],
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@open-file-viewer/core": ["packages/core/src/index.ts"],
      "@open-file-viewer/react": ["packages/react/src/index.tsx"],
      "@open-file-viewer/vue": ["packages/vue/src/index.ts"]
    },
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true
  }
}
